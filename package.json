{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Discord bot that reads user data from MySQL and sends it via DM.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/start.js",
    "bot": "node src/index.js",
    "clear-commands": "node src/clear-commands.js",
    "admin": "node src/admin.js",
    "admin:railway": "node -r dotenv/config src/admin.js dotenv_config_path=.env.railway",
    "import": "node src/import-data.js",
    "import:railway": "node -r dotenv/config src/import-data.js dotenv_config_path=.env.railway",
    "init-db": "node src/init-db.js",
    "migrate": "node src/migrate.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^16.4.5",
    "mysql2": "^3.15.2"
  }
}
